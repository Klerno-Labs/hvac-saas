generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

model PlanLimit {
  id                  String   @id @default(cuid())
  plan                Plan     @unique
  maxUsers            Int
  maxJobsPerMonth     Int
  maxActiveCustomers  Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WebhookEvent {
  id            String        @id @default(cuid())
  stripeEventId String        @unique
  type          String
  orgId         String?
  receivedAt    DateTime      @default(now())
  processedAt   DateTime?
  metadata      Json?
}

model User {
  id             String               @id @default(cuid())
  name           String?
  email          String?              @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  accounts       Account[]
  sessions       Session[]
  memberships    OrganizationMember[]
  jobNotes       JobNote[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model Organization {
  id                       String               @id @default(cuid())
  name                     String
  tradeType                String               @default("hvac")
  timezone                 String?
  phone                    String?
  email                    String?
  onboardingStatus         String               @default("not_started")
  stripeConnectedAccountId String?
  stripeChargesEnabled     Boolean              @default(false)
  stripePayoutsEnabled     Boolean              @default(false)
  stripeTerminalEnabled    Boolean              @default(false)
  collectionsEnabled       Boolean              @default(false)
  collectionsOverdue1Days  Int                  @default(7)
  collectionsOverdue2Days  Int                  @default(14)
  collectionsFinalDays     Int                  @default(30)
  smsEnabled               Boolean              @default(false)
  platformFeePercent       Float                @default(2.9)
  stripeCustomerId         String?              @unique
  stripeSubscriptionId     String?              @unique
  subscriptionStatus       SubscriptionStatus   @default(TRIALING)
  plan                     Plan                 @default(STARTER)
  trialEndsAt              DateTime?
  currentPeriodEnd         DateTime?
  readOnlyAt               DateTime?
  accountingProvider       String?
  accountingConnected      Boolean              @default(false)
  accountingLastSyncAt     DateTime?
  referralCode             String?              @unique
  referralCredits          Int                  @default(0)
  referredByOrgId          String?
  referredByOrg            Organization?        @relation("ReferredBy", fields: [referredByOrgId], references: [id])
  referrals                Organization[]       @relation("ReferredBy")
  members                  OrganizationMember[]
  customers                Customer[]
  jobs                     Job[]
  estimates                Estimate[]
  invoices                 Invoice[]
  payments                 Payment[]
  reminders                Reminder[]
  collectionAttempts       CollectionAttempt[]
  portalTokens             PortalToken[]
  accountingSyncRecords    AccountingSyncRecord[]
  accountingConnection     AccountingConnection?
  taxCodeMappings          TaxCodeMapping[]
  auditLogs                AuditLog[]
  teamInvites              TeamInvite[]
  assets                   ProofOfWorkAsset[]
  signatures               JobSignature[]
  events                   ActivityEvent[]
  recurringJobs            RecurringJob[]
  reviews                  CustomerReview[]
  inventoryItems           InventoryItem[]
  inventoryUsages          InventoryUsage[]
  equipment                Equipment[]
  equipmentServiceRecords  EquipmentServiceRecord[]
  jobNotes                 JobNote[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("owner")
  invitedAt      DateTime?
  acceptedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model TeamInvite {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String       @default("member")
  token          String       @unique
  invitedBy      String
  acceptedAt     DateTime?
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String?
  companyName    String?
  email          String?
  phone          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobs           Job[]
  invoices       Invoice[]
  reminders      Reminder[]
  portalTokens   PortalToken[]
  recurringJobs  RecurringJob[]
  reviews        CustomerReview[]
  equipment      Equipment[]
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model PortalToken {
  id             String       @id @default(cuid())
  token          String       @unique
  organizationId String
  customerId     String
  expiresAt      DateTime
  revokedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([customerId])
}

model Job {
  id              String       @id @default(cuid())
  organizationId  String
  customerId      String
  title           String
  status          String       @default("draft")
  scheduledFor    DateTime?
  completedAt     DateTime?
  technicianName  String?
  notes           String?
  workSummary     String?
  materialsUsed   String?
  completionNotes String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  estimates       Estimate[]
  invoices        Invoice[]
  reminders       Reminder[]
  assets          ProofOfWorkAsset[]
  signatures      JobSignature[]
  reviews         CustomerReview[]
  inventoryUsages InventoryUsage[]
  equipmentServiceRecords EquipmentServiceRecord[]
  jobNotes        JobNote[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([customerId])
}

// Appendable, idempotent field notes authored from the offline-first field PWA.
// clientId is assigned client-side so offline writes can be safely re-pushed
// (upsert keyed on clientId) without creating duplicates.
model JobNote {
  id             String   @id @default(cuid())
  clientId       String   @unique
  organizationId String
  jobId          String
  authorId       String
  authorName     String?
  body           String
  pending        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job            Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([jobId, createdAt])
}

model Estimate {
  id             String             @id @default(cuid())
  organizationId String
  jobId          String
  estimateNumber String
  status         String             @default("draft")
  scopeOfWork    String?
  terms          String?
  notes          String?
  subtotalCents  Int                @default(0)
  taxCents       Int                @default(0)
  totalCents     Int                @default(0)
  aiDraftUsed    Boolean            @default(false)
  sentAt         DateTime?
  viewedAt       DateTime?
  acceptedAt     DateTime?
  declinedAt     DateTime?
  decisionByName String?
  decisionByIp   String?
  signatureDataUrl String?
  declineReason  String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job            Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lineItems      EstimateLineItem[]
  reminders      Reminder[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId])
  @@index([jobId])
}

model EstimateLineItem {
  id             String   @id @default(cuid())
  estimateId     String
  name           String
  description    String?
  quantity       Int      @default(1)
  unitPriceCents Int      @default(0)
  lineTotalCents Int      @default(0)
  sortOrder      Int      @default(0)
  estimate       Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model Invoice {
  id                       String            @id @default(cuid())
  organizationId           String
  jobId                    String
  customerId               String
  invoiceNumber            String
  status                   String            @default("draft")
  descriptionOfWork        String?
  notes                    String?
  subtotalCents            Int               @default(0)
  taxCents                 Int               @default(0)
  totalCents               Int               @default(0)
  outstandingCents         Int               @default(0)
  dueDate                  DateTime?
  sentAt                   DateTime?
  paidAt                   DateTime?
  stripeCheckoutSessionId  String?              @unique
  collectionsPaused        Boolean              @default(false)
  organization             Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                      Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer                 Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lineItems                InvoiceLineItem[]
  payments                 Payment[]
  reminders                Reminder[]
  collectionAttempts       CollectionAttempt[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  @@index([organizationId])
  @@index([jobId])
}

model InvoiceLineItem {
  id             String  @id @default(cuid())
  invoiceId      String
  name           String
  description    String?
  quantity       Int     @default(1)
  unitPriceCents Int     @default(0)
  lineTotalCents Int     @default(0)
  sortOrder      Int     @default(0)
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id                  String       @id @default(cuid())
  organizationId      String
  invoiceId           String
  stripePaymentIntent String?      @unique
  amountCents         Int
  currency            String       @default("usd")
  method              String       @default("checkout")
  status              String       @default("pending")
  paidAt              DateTime?
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice             Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Reminder {
  id             String        @id @default(cuid())
  organizationId String
  title          String
  notes          String?
  reminderType   String        @default("general")
  status         String        @default("open")
  dueAt          DateTime?
  invoiceId      String?
  jobId          String?
  customerId     String?
  estimateId     String?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  job            Job?          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  estimate       Estimate?     @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model ProofOfWorkAsset {
  id             String       @id @default(cuid())
  organizationId String
  jobId          String
  fileUrl        String
  fileType       String
  fileSize       Int?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job            Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model JobSignature {
  id                String       @id @default(cuid())
  organizationId    String
  jobId             String
  signerName        String
  signatureImageUrl String
  signedAt          DateTime     @default(now())
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job               Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([jobId])
}

model CollectionAttempt {
  id             String       @id @default(cuid())
  organizationId String
  invoiceId      String
  stage          String
  status         String       @default("created")
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([invoiceId, stage])
  @@index([organizationId])
  @@index([invoiceId])
}

model AccountingSyncRecord {
  id             String       @id @default(cuid())
  organizationId String
  entityType     String
  entityId       String
  remoteId       String?
  syncToken      String?
  provider       String       @default("quickbooks")
  metadataJson   Json?
  syncStatus     String       @default("pending")
  errorMessage   String?
  lastSyncAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, entityType, entityId])
  @@index([organizationId])
  @@index([syncStatus])
}

model AccountingConnection {
  id                    String   @id @default(cuid())
  organizationId        String   @unique
  provider              String   @default("quickbooks")
  realmId               String
  accessToken           String
  refreshToken          String
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime?
  defaultTaxCodeRef     String?
  defaultItemRef        String?
  scope                 String?
  disconnectedAt        DateTime?
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TaxCodeMapping {
  id             String   @id @default(cuid())
  organizationId String
  label          String
  qboTaxCodeId   String
  isDefault      Boolean  @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, label])
  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  actorEmail     String?
  eventType      String
  targetType     String?
  targetId       String?
  metadata       Json?
  ipAddress      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([eventType])
  @@index([createdAt])
}

model ActivityEvent {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  eventName      String
  entityType     String?
  entityId       String?
  metadataJson   Json?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
}

model RecurringJob {
  id              String       @id @default(cuid())
  organizationId  String
  customerId      String
  title           String
  description     String?
  frequency       String       // 'monthly', 'quarterly', 'biannual', 'annual'
  nextDueDate     DateTime
  lastGeneratedAt DateTime?
  isActive        Boolean      @default(true)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer     @relation(fields: [customerId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([customerId])
}

model CustomerReview {
  id              String       @id @default(cuid())
  organizationId  String
  jobId           String       @unique
  customerId      String
  rating          Int
  comment         String?
  token           String       @unique
  submittedAt     DateTime?
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job             Job          @relation(fields: [jobId], references: [id])
  customer        Customer     @relation(fields: [customerId], references: [id])

  @@index([organizationId])
  @@index([token])
}

model InventoryItem {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  sku             String?
  description     String?
  unitCostCents   Int          @default(0)
  sellPriceCents  Int          @default(0)
  quantityOnHand  Int          @default(0)
  reorderPoint    Int          @default(0)
  category        String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  usages          InventoryUsage[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, sku])
}

model InventoryUsage {
  id              String        @id @default(cuid())
  organizationId  String
  inventoryItemId String
  jobId           String
  quantity        Int
  notes           String?
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  job             Job           @relation(fields: [jobId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([organizationId])
  @@index([jobId])
  @@index([inventoryItemId])
}

model Equipment {
  id                  String                   @id @default(cuid())
  organizationId      String
  customerId          String
  type                String                   // ac_condenser|furnace|heat_pump|mini_split|boiler|water_heater|thermostat|air_handler|ductwork|other
  make                String?
  model               String?
  serial              String?
  installDate         DateTime?
  installedByUs       Boolean                  @default(false)
  installerName       String?
  tonnage             Float?
  seer                Float?
  refrigerantType     String?
  btu                 Int?
  locationOnProperty  String?
  warrantyStartDate   DateTime?
  partsWarrantyMonths Int?
  laborWarrantyMonths Int?
  lastServicedAt      DateTime?
  nextServiceDueAt    DateTime?
  status              String                   @default("active") // active|retired
  notes               String?
  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer            Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceRecords      EquipmentServiceRecord[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([organizationId])
  @@index([customerId])
}

model EquipmentServiceRecord {
  id              String       @id @default(cuid())
  organizationId  String
  equipmentId     String
  jobId           String?
  serviceType     String       // tune-up|repair|install|inspection|warranty|other
  description     String?
  performedAt     DateTime
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  equipment       Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  job             Job?         @relation(fields: [jobId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([equipmentId])
  @@index([jobId])
}

// Append-only rate limit hit log. Intentionally org-agnostic: auth and public
// portal endpoints hit this before any org/session context is known.
model RateLimitHit {
  id         String   @id @default(cuid())
  bucket     String   // e.g. "auth:login", "portal:token", "public:pay"
  identifier String   // composite key: "<ip>|<id>" (id = email/token-hash/"-")
  hitAt      DateTime @default(now())

  @@index([bucket, identifier, hitAt])
  @@index([hitAt])
}
