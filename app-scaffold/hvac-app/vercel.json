{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/recurring/generate",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/collections/run",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/reminders/send",
      "schedule": "0 * * * *"
    }
  ]
}
